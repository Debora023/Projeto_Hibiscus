@baseUrl = http://localhost:3000

##################################################
# 🛍️ PRODUTOS
##################################################

### Criar produto
POST {{baseUrl}}/produtos
Content-Type: application/json

{
  "nome": "Chá para cólica",
  "preco": 19.90,
  "descricao": "Chá natural calmante",
  "categoria": "Saúde",
  "estoque": 50
}

###

### Listar produtos
GET {{baseUrl}}/produtos

###

### Buscar produto por ID
GET {{baseUrl}}/produtos/1

###

### Atualizar produto
PUT {{baseUrl}}/produtos/1
Content-Type: application/json

{
  "nome": "Chá calmante premium",
  "preco": 24.90
}

###

### Deletar produto
DELETE {{baseUrl}}/produtos/1


##################################################
# 👤 CLIENTES
##################################################

### Criar cliente
POST {{baseUrl}}/clientes
Content-Type: application/json

{
  "nome": "Maria Silva",
  "email": "maria@email.com",
  "telefone": "13999999999",
  "endereco": "Rua A, 123",
  "cidade": "Guarujá"
}

###

### Listar clientes
GET {{baseUrl}}/clientes

###

### Buscar cliente por ID
GET {{baseUrl}}/clientes/1

###

### Atualizar cliente
PUT {{baseUrl}}/clientes/1
Content-Type: application/json

{
  "nome": "Maria Souza"
}

###

### Deletar cliente
DELETE {{baseUrl}}/clientes/1


##################################################
# 👩‍💻 USUÁRIOS
##################################################

### Criar usuário
POST {{baseUrl}}/usuarios
Content-Type: application/json

{
  "nome": "Admin",
  "email": "admin@hibiscus.com",
  "senha": "123456",
  "role": "admin"
}

###

### Listar usuários
GET {{baseUrl}}/usuarios

###

### Buscar usuário por ID
GET {{baseUrl}}/usuarios/1

###

### Atualizar usuário
PUT {{baseUrl}}/usuarios/1
Content-Type: application/json

{
  "nome": "Novo Nome"
}

###

### Deletar usuário
DELETE {{baseUrl}}/usuarios/1


##################################################
# 🛒 PEDIDOS
##################################################

### Criar pedido
POST {{baseUrl}}/pedidos
Content-Type: application/json

{
  "cliente_id": 1,
  "itens": [
    {
      "produto_id": 1,
      "quantidade": 2
    }
  ],
  "valor_total": 39.80,
  "status": "pendente"
}

###

### Listar pedidos
GET {{baseUrl}}/pedidos

###

### Buscar pedido por ID
GET {{baseUrl}}/pedidos/1

###

### Atualizar status do pedido
PUT {{baseUrl}}/pedidos/1
Content-Type: application/json

{
  "status": "finalizado"
}

###

### Deletar pedido
DELETE {{baseUrl}}/pedidos/1